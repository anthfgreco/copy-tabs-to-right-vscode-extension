{
  "name": "copy-tabs-to-right",
  "displayName": "Copy Tabs to Right",
  "version": "1.0.5",
  "description": "Copy all open tabs to the right of the current tab",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anthfgreco/copy-tabs-to-right-vscode-extension.git"
  },
  "publisher": "AnthonyGreco",
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm compile",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "test": "pnpm compile && vscode-test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "pnpm fmt:check && pnpm lint && pnpm compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.20.1",
    "@types/vscode": "^1.67.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^5.9.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "copyTabsToRight.copyToClipboard",
        "title": "Copy Opened Files to Clipboard (To the Right)"
      }
    ],
    "keybindings": [
      {
        "command": "copyTabsToRight.copyToClipboard",
        "key": "ctrl+alt+]",
        "when": "editorTextFocus && !inputFocus",
        "mac": "cmd+alt+]"
      }
    ]
  },
  "activationEvents": [],
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.67.0"
  },
  "packageManager": "pnpm@11.12.0"
}
